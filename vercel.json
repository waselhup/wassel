{
    "version": 2,
    "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
    "buildCommand": "pnpm run build",
    "outputDirectory": "dist/public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}