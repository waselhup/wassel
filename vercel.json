{
    "version": 2,
    "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
    "buildCommand": "pnpm run build && npx esbuild server/_core/vercel.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/api/index.js",
    "outputDirectory": "dist/public",
    "functions": {
        "api/index.js": {
            "includeFiles": "dist/api/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}