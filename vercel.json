{
    "version": 2,
    "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
    "buildCommand": "pnpm run build",
    "outputDirectory": "dist/public",
    "crons": [
        {
            "path": "/api/cron/campaign-runner",
            "schedule": "* * * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}