{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "api/fonts/**"
    }
  },
  "crons": [
    { "path": "/api/cron/anthropic-health", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/check-renewals", "schedule": "0 6 * * *" },
    { "path": "/api/cron/check-abandoned-signups", "schedule": "0 * * * *" },
    { "path": "/api/cron/services-heartbeat", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/al-mukhadram-daily", "schedule": "0 7 * * *" },
    { "path": "/api/cron/hassan-hot-leads", "schedule": "0 8 * * *" },
    { "path": "/api/cron/fatima-friction-scan", "schedule": "0 6 * * *" },
    { "path": "/api/cron/fatima-weekly-report", "schedule": "0 8 * * 1" },
    { "path": "/api/cron/email-sequences-runner", "schedule": "0 * * * *" },
    { "path": "/api/cron/recompute-health-scores", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/dhai-daily-sweep", "schedule": "0 4 * * *" },
    { "path": "/api/cron/hussein-auto-resolve", "schedule": "0 * * * *" },
    { "path": "/api/cron/mohammed-reconcile", "schedule": "0 23 * * *" },
    { "path": "/api/cron/mohammed-snapshot", "schedule": "0 0 * * *" },
    { "path": "/api/cron/war-room-weekly-journal", "schedule": "0 5 * * 0" },
    { "path": "/api/cron/dashboard-suggestions", "schedule": "0 23 * * *" },
    { "path": "/api/cron/expire-bonuses", "schedule": "0 0 * * *" },
    { "path": "/api/cron/subscription-renewals", "schedule": "0 1 * * *" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "wassel-alpha.vercel.app" }],
      "destination": "https://wasselhub.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.wasselhub.com" }],
      "destination": "https://wasselhub.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/unsubscribe", "destination": "/api/index.js" },
    { "source": "/((?!api/|unsubscribe|fonts/).*)", "destination": "/index.html" }
  ]
}
