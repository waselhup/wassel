# Staging environment
# Copy all variables from production (.env.production / Vercel env vars)
# Then change VITE_APP_ENV to staging

VITE_APP_ENV=staging

# Use separate Supabase project for staging if possible
# VITE_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_STAGING_ANON_KEY
