  "faq": {
    "title": "Frequently Asked Questions",
    "subtitle": "Answers to common questions",
    "items": [
      {
        "question": "Is Wassel free to try?",
        "answer": "Yes. You can sign up for free and get starter tokens to analyze your LinkedIn profile and tailor a CV before upgrading."
      },
      {
        "question": "Is my data private and secure?",
        "answer": "Absolutely. Your data is stored on Supabase with row-level security and fully complies with Saudi PDPL."
      },
      {
        "question": "Do I need a LinkedIn Premium account?",
        "answer": "No. Wassel works with any free LinkedIn account — no premium subscription required."
      },
      {
        "question": "How does AI write the emails?",
        "answer": "Wassel uses Claude AI to craft personalized, professional B2B emails in Arabic or English, tailored to each decision-maker."
      },
      {
        "question": "Do you support Arabic and English?",
        "answer": "Yes. Wassel is Arabic-first with full RTL support and Cairo font, plus complete English localization."
      },
      {
        "question": "Can I cancel anytime?",
        "answer": "Yes. All subscriptions are month-to-month and you can cancel from the dashboard at any time with no hidden fees."
      }
    ]
  },
